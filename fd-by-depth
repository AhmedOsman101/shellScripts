# --- DESCRIPTION --- #
# Wrapper script for fd which sorts results by depth
# --- DEPENDENCIES --- #
# - fd | fdfind (fd-find)
# --- END SIGNATURE --- #

set -eo pipefail
trap 'exit 1' SIGUSR1

eval "$(include "check-deps")"
checkDeps "$0"

# ---  Main script logic --- #
# Run fd with whatever args you pass, then sort the output by depth
fd.sh "$@" |
  awk -F/ '{ print NF, $0 }' |
  sort -n |
  cut -d' ' -f2-
