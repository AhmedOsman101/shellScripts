trap 'exit 1' SIGUSR1

eval "$(include "lib/cmdarg.sh")"
eval "$(include "check-deps")"

checkDeps "$0"
cmdarg_info "header" "$(get-desc "$0")"
cmdarg_parse "$@"
# ---  Main script logic --- #
mapfile -t arr < <(fd.sh ' ' -t f -p "${PWD}")

for file in "${arr[@]}"; do
  renamefile "${file}" "${file// /_}"
done
